<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>SecurePass - Password Utility</title>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary-fixed-variant": "#763400",
                        "on-tertiary-fixed": "#321200",
                        "on-primary-container": "#000512",
                        "primary-fixed-dim": "#aac7ff",
                        "surface-container-highest": "#e0e2eb",
                        outline: "#717785",
                        "surface-container-low": "#f1f3fc",
                        "inverse-primary": "#aac7ff",
                        "secondary-fixed": "#d6e3ff",
                        "on-secondary-container": "#3f5881",
                        background: "#0a0a14",
                        "surface-variant": "#e0e2eb",
                        "on-secondary-fixed-variant": "#2d476f",
                        error: "#ffb4ab",
                        "on-primary-fixed-variant": "#00458d",
                        "on-primary": "#ffffff",
                        "on-error": "#690005",
                        "on-primary-fixed": "#001b3e",
                        surface: "#0f111a",
                        "on-surface-variant": "#c1c6d5",
                        "on-secondary-fixed": "#001b3d",
                        "inverse-surface": "#e0e2eb",
                        "surface-container": "#1b1f2b",
                        "tertiary-fixed": "#ffdbc9",
                        "on-tertiary": "#ffffff",
                        tertiary: "#ffb68c",
                        "inverse-on-surface": "#181c22",
                        "surface-container-high": "#252a3a",
                        "secondary-fixed-dim": "#aec7f7",
                        "tertiary-container": "#c05900",
                        "surface-container-lowest": "#0a0c14",
                        primary: "#aac7ff",
                        "on-tertiary-container": "#0d0300",
                        "tertiary-fixed-dim": "#ffb68c",
                        "surface-tint": "#aac7ff",
                        secondary: "#aec7f7",
                        "primary-fixed": "#d6e3ff",
                        "surface-bright": "#353945",
                        "error-container": "#93000a",
                        "primary-container": "#00458d",
                        "surface-dim": "#0f111a",
                        "on-error-container": "#ffdad6",
                        "on-background": "#e0e2eb",
                        "secondary-container": "#2d476f",
                        "outline-variant": "#414753",
                        "on-surface": "#e0e2eb",
                        "on-secondary": "#11305f"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    },
                    spacing: {
                        sm: "8px",
                        base: "8px",
                        "container-max": "1280px",
                        md: "16px",
                        lg: "24px",
                        gutter: "16px",
                        xs: "4px",
                        xl: "32px",
                        "2xl": "48px",
                        margin: "24px"
                    },
                    fontFamily: {
                        "headline-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        display: ["Inter"],
                        "body-lg": ["Inter"],
                        "label-md": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "body-md": ["Inter"],
                        headline: ["Inter"],
                        body: ["Inter"],
                        label: ["Inter"],
                        "body-sm": ["Inter"],
                        "headline-sm": ["Inter"]
                    },
                    fontSize: {
                        "headline-md": ["32px", {lineHeight: "40px", fontWeight: "600"}],
                        "headline-lg": ["48px", {lineHeight: "56px", fontWeight: "700"}],
                        display: ["36px", {lineHeight: "44px", letterSpacing: "-0.02em", fontWeight: "700"}],
                        "body-lg": ["18px", {lineHeight: "28px", fontWeight: "400"}],
                        "label-md": ["12px", {lineHeight: "16px", letterSpacing: "0.5px", fontWeight: "500"}],
                        "headline-lg-mobile": ["24px", {lineHeight: "32px", fontWeight: "600"}],
                        "body-md": ["16px", {lineHeight: "24px", fontWeight: "400"}],
                        "body-sm": ["14px", {lineHeight: "20px", fontWeight: "400"}],
                        "headline-sm": ["24px", {lineHeight: "32px", fontWeight: "600"}]
                    }
                }
            }
        };
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        .mode-active {
            background-color: #aac7ff;
            color: #001b3e;
        }
        .strength-segment {
            transition: background-color 0.3s ease, flex 0.3s ease;
        }
        .fade-enter-active {
            animation: fadeIn 0.3s ease forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .custom-scroll::-webkit-scrollbar { width: 4px; }
        .custom-scroll::-webkit-scrollbar-track { background: transparent; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #414753; border-radius: 10px; }

        canvas#bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
        }

        .deep-rainbow-border {
            position: relative;
            background: rgba(15, 17, 26, 0.85);
            border: 2px solid transparent;
            background-clip: padding-box;
        }
        .deep-rainbow-border::after {
            content: '';
            position: absolute;
            top: -2px; bottom: -2px;
            left: -2px; right: -2px;
            background: linear-gradient(135deg, #4a1d4a, #1d1d4a, #1d4a3a, #4a4a1d);
            z-index: -1;
            border-radius: inherit;
            opacity: 0.8;
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body-md h-screen flex flex-col overflow-hidden transition-colors duration-300">
<canvas id="bg-animation" width="1280" height="1024"></canvas>

<header class="bg-surface-container-lowest/70 backdrop-blur-xl border-b border-outline-variant/30 shadow-sm top-0 z-50">
    <div class="flex justify-between items-center w-full px-lg h-16 max-w-container-max mx-auto">
        <div class="text-headline-sm font-bold text-primary cursor-pointer tracking-tight" onclick="setActiveView('main')">SecurePass <span class="text-secondary opacity-80">AK7</span></div>
        <div class="hidden md:flex gap-xl items-center">
            <button class="py-2 font-label-md text-label-md transition-all hover:text-on-surface text-primary font-bold border-b-2 border-primary" id="nav-dashboard" onclick="setActiveView('main')">Dashboard</button>
            <button class="transition-colors px-md py-2 font-label-md text-label-md text-on-surface/70 hover:text-on-surface" id="nav-guide" onclick="setActiveView('guide')">Security Guide</button>
            <button class="text-on-surface/70 hover:text-on-surface transition-colors px-md py-2 font-label-md text-label-md" id="nav-vault" onclick="setActiveView('vault')">Vault</button>
        </div>
        <div class="flex items-center gap-md">
            <button class="material-symbols-outlined text-primary p-sm hover:bg-surface-container-high rounded-full transition-all" onclick="toggleSettings()">settings</button>
        </div>
    </div>
</header>

<main class="flex-1 relative flex items-center justify-center p-md">
    <div class="absolute top-4 right-4 z-50 w-64 bg-surface-container-high border border-outline-variant/30 rounded-xl shadow-2xl p-lg flex flex-col gap-md fade-enter-active hidden" id="settings-panel">
        <div class="flex justify-between items-center">
            <h3 class="font-label-md text-sm uppercase tracking-wider opacity-60">Settings</h3>
            <button class="material-symbols-outlined text-sm" onclick="toggleSettings()">close</button>
        </div>
        <div class="space-y-md">
            <div class="flex items-center justify-between">
                <span class="text-body-md">Advanced Mode</span>
                <button class="w-10 h-5 rounded-full bg-surface-container-highest relative transition-colors">
                    <div class="absolute top-1 left-1 w-3 h-3 rounded-full bg-primary transition-all"></div>
                </button>
            </div>
            <div class="border-t border-outline-variant pt-md">
                <button class="w-full text-left text-body-md text-error flex items-center gap-sm" onclick="logoutVault()">
                    <span class="material-symbols-outlined text-sm">logout</span> Sign Out
                </button>
            </div>
        </div>
    </div>

    <div class="view-content relative z-10 w-full max-w-2xl deep-rainbow-border backdrop-blur-xl border-outline-variant/20 rounded-xl shadow-2xl p-lg flex flex-col gap-xl overflow-hidden min-h-[540px]" id="view-main">
        <div class="flex p-xs bg-surface-container-high/50 rounded-lg">
            <button class="flex-1 flex items-center justify-center gap-sm py-2 rounded-md transition-all font-label-md text-label-md text-on-surface/60 hover:bg-surface-container-highest" id="btn-check" onclick="setMode('check')">
                <span class="material-symbols-outlined">lock_open</span> Check Strength
            </button>
            <button class="flex-1 flex items-center justify-center gap-sm py-2 rounded-md transition-all font-label-md text-label-md mode-active" id="btn-generate" onclick="setMode('generate')">
                <span class="material-symbols-outlined">enhanced_encryption</span> Generate Password
            </button>
        </div>

        <div class="flex flex-col gap-xl fade-enter-active hidden" id="section-check">
            <div class="text-center space-y-sm">
                <h2 class="font-headline-lg text-headline-md text-primary">Password Strength</h2>
                <p class="text-on-surface-variant font-body-md">Analyze your password security against local processing algorithms.</p>
            </div>
            <div class="space-y-lg">
                <div class="relative">
                    <input class="w-full h-14 px-lg text-body-lg font-body-lg border-2 border-outline-variant bg-surface-container/50 rounded-lg focus:outline-none focus:border-primary transition-all pr-12 placeholder:text-outline" id="strength-input" placeholder="Enter your password..." type="password">
                    <button class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline hover:text-primary transition-colors" onclick="toggleVisibility('strength-input')">visibility</button>
                </div>
                <div class="space-y-sm">
                    <div class="flex justify-between font-label-md text-label-md px-1">
                        <span class="text-on-surface-variant" id="strength-label">Security Level: Unknown</span>
                        <span class="text-outline" id="entropy-label">0 bits</span>
                    </div>
                    <div class="flex gap-1.5 h-2 w-full rounded-full overflow-hidden bg-surface-container-high">
                        <div class="strength-segment h-full flex-1 bg-outline/20" id="meter-1"></div>
                        <div class="strength-segment h-full flex-1 bg-outline/20" id="meter-2"></div>
                        <div class="strength-segment h-full flex-1 bg-outline/20" id="meter-3"></div>
                        <div class="strength-segment h-full flex-1 bg-outline/20" id="meter-4"></div>
                    </div>
                </div>
                <div class="p-md bg-primary-container/20 rounded-lg border-l-4 border-primary">
                    <div class="flex gap-sm">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">info</span>
                        <div class="text-body-md text-on-surface-variant leading-relaxed">
                            <span class="font-bold text-primary">ADVICE:</span> Length is the most critical factor for entropy. Aim for at least 14 characters using a variety of sets.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-xl" id="section-generate">
            <div class="text-center space-y-sm">
                <h2 class="font-headline-lg text-headline-md text-primary">Secure Generator</h2>
                <p class="text-on-surface-variant font-body-md">Create cryptographically strong passwords instantly.</p>
            </div>
            <div class="space-y-xl">
                <div class="flex gap-sm">
                    <div class="flex-1 h-14 flex items-center px-lg bg-surface-container/50 border border-outline-variant rounded-lg text-body-lg font-mono tracking-widest overflow-hidden overflow-x-auto whitespace-nowrap" id="generated-output">:}0J$AY&gt;A3Ap</div>
                    <button class="w-14 h-14 flex items-center justify-center bg-primary text-on-primary rounded-lg hover:opacity-90 active:scale-95 transition-all shadow-lg" onclick="copyToClipboard()" title="Copy">
                        <span class="material-symbols-outlined">content_copy</span>
                    </button>
                    <button class="w-14 h-14 flex items-center justify-center bg-secondary-container text-on-secondary-container rounded-lg hover:opacity-90 active:scale-95 transition-all shadow-lg" onclick="saveToVault()" title="Save to Vault">
                        <span class="material-symbols-outlined">save</span>
                    </button>
                    <button class="h-14 px-lg bg-primary text-on-primary rounded-lg hover:opacity-90 active:scale-95 transition-all font-label-md text-label-md flex items-center gap-sm shadow-lg" onclick="generatePassword()">
                        <span class="material-symbols-outlined">refresh</span> NEW
                    </button>
                </div>
                <div class="grid grid-cols-2 gap-lg">
                    <div class="space-y-sm">
                        <label class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Length</label>
                        <div class="flex bg-surface-container-high/50 p-1 rounded-lg border border-outline-variant">
                            <button class="len-btn flex-1 py-1.5 rounded font-label-md text-label-md transition-all hover:bg-surface-container-highest" data-val="8" onclick="setLength(8)">8</button>
                            <button class="len-btn flex-1 py-1.5 rounded font-label-md text-label-md transition-all bg-primary text-on-primary shadow-sm" data-val="12" onclick="setLength(12)">12</button>
                            <button class="len-btn flex-1 py-1.5 rounded font-label-md text-label-md transition-all hover:bg-surface-container-highest" data-val="16" onclick="setLength(16)">16</button>
                        </div>
                    </div>
                    <div class="space-y-sm">
                        <label class="font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Complexity</label>
                        <div class="flex flex-wrap gap-md pt-2">
                            <label class="flex items-center gap-xs cursor-pointer group">
                                <input checked="" class="w-4 h-4 rounded text-primary focus:ring-primary border-outline-variant bg-transparent" id="opt-alpha" type="checkbox" onchange="generatePassword()">
                                <span class="text-label-md font-label-md text-on-surface-variant group-hover:text-primary">Letters</span>
                            </label>
                            <label class="flex items-center gap-xs cursor-pointer group">
                                <input checked="" class="w-4 h-4 rounded text-primary focus:ring-primary border-outline-variant bg-transparent" id="opt-num" type="checkbox" onchange="generatePassword()">
                                <span class="text-label-md font-label-md text-on-surface-variant group-hover:text-primary">Nums</span>
                            </label>
                            <label class="flex items-center gap-xs cursor-pointer group">
                                <input checked="" class="w-4 h-4 rounded text-primary focus:ring-primary border-outline-variant bg-transparent" id="opt-sym" type="checkbox" onchange="generatePassword()">
                                <span class="text-label-md font-label-md text-on-surface-variant group-hover:text-primary">Symbols</span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="view-content relative z-10 w-full max-w-2xl deep-rainbow-border backdrop-blur-xl border-outline-variant/20 rounded-xl shadow-2xl p-lg flex flex-col gap-xl overflow-hidden min-h-[540px] fade-enter-active hidden" id="view-guide">
        <div class="text-center space-y-sm">
            <h2 class="font-headline-lg text-headline-md text-primary">Security Guide</h2>
            <p class="text-on-surface-variant font-body-md">Master the art of digital self-defense.</p>
        </div>
        <div class="flex-1 overflow-y-auto custom-scroll pr-2 space-y-lg">
            <section class="space-y-lg">
                <div class="flex gap-lg items-start group">
                    <div class="w-10 h-10 rounded-xl bg-primary text-on-primary flex items-center justify-center shrink-0 font-bold shadow-lg group-hover:scale-110 transition-transform">1</div>
                    <div>
                        <h3 class="font-headline-md text-lg text-on-surface">Checking Strength</h3>
                        <p class="text-body-md text-on-surface-variant mt-2 leading-relaxed">Our analyzer uses a modified zxcvbn-like algorithm to determine real-world crack resistance. A password's length contributes exponentially more to security than simple character variety.</p>
                    </div>
                </div>
                <div class="flex gap-lg items-start group">
                    <div class="w-10 h-10 rounded-xl bg-secondary text-on-secondary flex items-center justify-center shrink-0 font-bold shadow-lg group-hover:scale-110 transition-transform">2</div>
                    <div>
                        <h3 class="font-headline-md text-lg text-on-surface">Generating Passwords</h3>
                        <p class="text-body-md text-on-surface-variant mt-2 leading-relaxed">For modern systems, 16 characters is the minimum recommended length. Ensure you combine alphanumeric characters with symbols to maximize the search space for attackers.</p>
                    </div>
                </div>
                <div class="flex gap-lg items-start group">
                    <div class="w-10 h-10 rounded-xl bg-tertiary text-on-tertiary flex items-center justify-center shrink-0 font-bold shadow-lg group-hover:scale-110 transition-transform">3</div>
                    <div>
                        <h3 class="font-headline-md text-lg text-on-surface">Secure Storage</h3>
                        <p class="text-body-md text-on-surface-variant mt-2 leading-relaxed">Never reuse passwords. Store them in your local Secure Vault. Your PIN acts as a salt for the local decryption process; it is never transmitted.</p>
                    </div>
                </div>
            </section>
        </div>
        <button class="w-full py-md bg-surface-container-high rounded-lg font-label-md hover:bg-surface-container-highest transition-colors border border-outline-variant/30 text-primary" onclick="setActiveView('main')">Return to Dashboard</button>
    </div>

    <div class="view-content hidden relative z-10 w-full max-w-2xl deep-rainbow-border backdrop-blur-xl border-outline-variant/20 rounded-xl shadow-2xl p-lg flex flex-col gap-xl overflow-hidden min-h-[540px] fade-enter-active" id="view-vault">
        <div class="flex-1 flex flex-col items-center justify-center gap-xl" id="vault-auth">
            <div class="text-center space-y-sm">
                <span class="material-symbols-outlined text-display text-primary" style="font-size: 64px;">encrypted</span>
                <h2 class="font-headline-lg text-headline-md text-primary">Secure Vault</h2>
                <p class="text-on-surface-variant font-body-md">Authentication required to access local encrypted storage.</p>
            </div>
            <div class="w-full max-w-xs space-y-md">
                <input class="w-full h-12 px-md border border-outline-variant bg-surface-container/50 rounded-lg focus:outline-none focus:border-primary text-center tracking-[1em] text-xl" id="vault-pin" placeholder="PIN" type="password">
                <button class="w-full h-12 bg-primary text-on-primary rounded-lg font-label-md hover:opacity-90 transition-all shadow-lg" onclick="loginVault()">Decrypt &amp; Sign In</button>
                <p class="text-xs text-center text-outline opacity-70">Client-side only. Your data never leaves this device.</p>
            </div>
        </div>
        <div class="hidden flex-1 flex flex-col gap-lg" id="vault-content">
            <div class="flex justify-between items-center">
                <h2 class="font-headline-lg text-headline-md text-primary">Stored Credentials</h2>
                <button class="px-md py-1.5 rounded-full bg-error/10 text-error font-bold text-xs uppercase tracking-widest hover:bg-error hover:text-on-error transition-all" onclick="logoutVault()">Lock Vault</button>
            </div>
            <div class="flex-1 overflow-y-auto custom-scroll pr-2 space-y-sm" id="vault-list">
                <div class="text-center py-12 opacity-50 italic text-body-md">Your vault is currently empty.</div>
            </div>
        </div>
    </div>
</main>

<footer class="bg-surface-container-lowest/50 backdrop-blur-md border-t border-outline-variant/20 z-50 transition-colors">
    <div class="flex justify-between items-center w-full px-lg py-4 max-w-container-max mx-auto">
        <div class="text-label-md font-bold text-primary tracking-wide">SecurePass <span class="opacity-50">v7.0</span></div>
        <div class="text-on-surface-variant font-label-md text-xs hidden sm:block uppercase tracking-widest">Local Processing • Zero Data Logging</div>
        <div class="flex gap-lg"></div>
    </div>
</footer>

<script>
    // Background Shader Implementation
    const canvas = document.getElementById('bg-animation');
    const gl = canvas.getContext('webgl');

    const vertexSource = `
        attribute vec2 position;
        varying vec2 v_texCoord;
        void main() {
            v_texCoord = (position + 1.0) / 2.0;
            gl_Position = vec4(position, 0.0, 1.0);
        }
    `;

    const fragmentSource = `
        precision highp float;
        varying vec2 v_texCoord;
        uniform float u_time;
        uniform vec2 u_resolution;

        vec3 getAnimeColor(float t) {
            vec3 c1 = vec3(0.05, 0.05, 0.15); 
            vec3 c2 = vec3(0.2, 0.1, 0.3);    
            vec3 c3 = vec3(0.1, 0.15, 0.4);   
            vec3 c4 = vec3(0.4, 0.2, 0.35);   
            
            float pulse = sin(t * 0.2) * 0.5 + 0.5;
            return mix(mix(c1, c2, pulse), mix(c3, c4, 1.0 - pulse), sin(t * 0.1) * 0.5 + 0.5);
        }

        float noise(vec2 p) {
            return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
        }

        void main() {
            vec2 uv = v_texCoord;
            float t = u_time * 0.3;
            
            vec2 p1 = uv + vec2(sin(t * 0.7), cos(t * 0.5)) * 0.2;
            vec2 p2 = uv + vec2(cos(t * 0.4), sin(t * 0.6)) * 0.3;
            
            float val = noise(floor(p1 * 5.0)) * 0.1;
            val += sin(p1.x * 3.0 + t) * 0.2;
            val += cos(p2.y * 2.0 - t * 0.8) * 0.2;
            
            vec3 color = getAnimeColor(t + val);
            
            float stars = pow(noise(floor(uv * 100.0)), 20.0) * (sin(u_time * 2.0 + noise(floor(uv * 100.0)) * 10.0) * 0.5 + 0.5);
            color += stars * 0.3;
            
            gl_FragColor = vec4(color, 1.0);
        }
    `;

    function createShader(gl, type, source) {
        const shader = gl.createShader(type);
        gl.shaderSource(shader, source);
        gl.compileShader(shader);
        return shader;
    }

    const program = gl.createProgram();
    gl.attachShader(program, createShader(gl, gl.VERTEX_SHADER, vertexSource));
    gl.attachShader(program, createShader(gl, gl.FRAGMENT_SHADER, fragmentSource));
    gl.linkProgram(program);

    const positionBuffer = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, positionBuffer);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]), gl.STATIC_DRAW);

    const positionLocation = gl.getAttribLocation(program, 'position');
    const timeLocation = gl.getUniformLocation(program, 'u_time');
    const resolutionLocation = gl.getUniformLocation(program, 'u_resolution');

    function render(time) {
        if (canvas.width !== window.innerWidth || canvas.height !== window.innerHeight) {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            gl.viewport(0, 0, canvas.width, canvas.height);
        }

        gl.useProgram(program);
        gl.enableVertexAttribArray(positionLocation);
        gl.vertexAttribPointer(positionLocation, 2, gl.FLOAT, false, 0, 0);

        gl.uniform1f(timeLocation, time * 0.001);
        gl.uniform2f(resolutionLocation, canvas.width, canvas.height);

        gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
        requestAnimationFrame(render);
    }
    requestAnimationFrame(render);

    // State
    let currentMode = 'generate';
    let passLength = 12;
    let currentView = 'main';
    let isLoggedIn = false;
    let vaultData = [];

    // Navigation & View Switching
    function setActiveView(view) {
        currentView = view;
        const views = ['view-main', 'view-guide', 'view-vault'];
        const navs = ['nav-dashboard', 'nav-guide', 'nav-vault'];

        views.forEach(v => document.getElementById(v).classList.add('hidden'));
        document.getElementById(`view-${view}`).classList.remove('hidden');

        navs.forEach(n => {
            const el = document.getElementById(n);
            el.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary');
            el.classList.add('text-on-surface/70');
        });

        const activeId = view === 'main' ? 'nav-dashboard' : (view === 'guide' ? 'nav-guide' : 'nav-vault');
        const activeNav = document.getElementById(activeId);
        activeNav.classList.remove('text-on-surface/70');
        activeNav.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary');
        
        document.getElementById('settings-panel').classList.add('hidden');
    }

    function toggleSettings() {
        const panel = document.getElementById('settings-panel');
        panel.classList.toggle('hidden');
    }

    function setMode(mode) {
        currentMode = mode;
        const btnCheck = document.getElementById('btn-check');
        const btnGenerate = document.getElementById('btn-generate');
        const secCheck = document.getElementById('section-check');
        const secGenerate = document.getElementById('section-generate');

        if (mode === 'check') {
            btnCheck.classList.add('mode-active');
            btnCheck.classList.remove('text-on-surface/60', 'hover:bg-surface-container-highest');
            btnGenerate.classList.remove('mode-active');
            btnGenerate.classList.add('text-on-surface/60', 'hover:bg-surface-container-highest');
            
            secCheck.classList.remove('hidden');
            secGenerate.classList.add('hidden');
        } else {
            btnGenerate.classList.add('mode-active');
            btnGenerate.classList.remove('text-on-surface/60', 'hover:bg-surface-container-highest');
            btnCheck.classList.remove('mode-active');
            btnCheck.classList.add('text-on-surface/60', 'hover:bg-surface-container-highest');

            secGenerate.classList.remove('hidden');
            secCheck.classList.add('hidden');
        }
    }

    // Input Visibility Toggle
    function toggleVisibility(id) {
        const el = document.getElementById(id);
        el.type = el.type === 'password' ? 'text' : 'password';
    }

    // Clipboard Copy
    function copyToClipboard() {
        const text = document.getElementById('generated-output').innerText;
        navigator.clipboard.writeText(text).then(() => {
            alert("Password copied to clipboard!");
        });
    }

    const strengthInput = document.getElementById('strength-input');
    strengthInput.addEventListener('input', (e) => {
        const val = e.target.value;
        const label = document.getElementById('strength-label');
        const entropyLabel = document.getElementById('entropy-label');
        
        let score = 0;
        if (val.length >= 8) score++;
        if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        if (val.length >= 14) score = Math.max(score, 4);

        const meters = [
            document.getElementById('meter-1'),
            document.getElementById('meter-2'),
            document.getElementById('meter-3'),
            document.getElementById('meter-4')
        ];

        meters.forEach(m => m.style.backgroundColor = 'rgba(65, 71, 83, 0.4)');

        if (val.length === 0) {
            label.innerText = 'Security Level: Unknown';
            entropyLabel.innerText = '0 bits';
            return;
        }

        const colors = {
            1: '#ffb4ab', 
            2: '#aec7f7',
            3: '#34e5a6',
            4: '#00ffaa' 
        };

        const labels = ['Weak', 'Medium', 'Strong', 'Excellent'];
        label.innerText = `Security Level: ${labels[score-1] || 'Very Weak'}`;
        label.style.color = colors[score] || '#ffb4ab';
        entropyLabel.innerText = `${Math.floor(val.length * 4.7)} bits`;

        for (let i = 0; i < score; i++) {
            meters[i].style.backgroundColor = colors[score] || '#ffb4ab';
        }
    });

    function setLength(l) {
        passLength = l;
        document.querySelectorAll('.len-btn').forEach(btn => {
            if (parseInt(btn.dataset.val) === l) {
                btn.classList.add('bg-primary', 'text-on-primary', 'shadow-sm');
                btn.classList.remove('hover:bg-surface-container-highest');
            } else {
                btn.classList.remove('bg-primary', 'text-on-primary', 'shadow-sm');
                btn.classList.add('hover:bg-surface-container-highest');
            }
        });
        generatePassword();
    }

    function generatePassword() {
        const useAlpha = document.getElementById('opt-alpha').checked;
        const useNum = document.getElementById('opt-num').checked;
        const useSym = document.getElementById('opt-sym').checked;

        const alpha = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
        const num = "0123456789";
        const sym = "!@#$%^&*()_+~`|}{[]:;?><,./-=";
        
        let charset = "";
        if (useAlpha) charset += alpha;
        if (useNum) charset += num;
        if (useSym) charset += sym;
        if (!charset) charset = alpha;

        let retVal = "";
        for (let i = 0, n = charset.length; i < passLength; ++i) {
            retVal += charset.charAt(Math.floor(Math.random() * n));
        }
        document.getElementById('generated-output').innerText = retVal;
    }

    function loginVault() {
        const pin = document.getElementById('vault-pin').value;
        if(pin.length >= 4) {
            isLoggedIn = true;
            document.getElementById('vault-auth').classList.add('hidden');
            document.getElementById('vault-content').classList.remove('hidden');
            renderVault();
        } else {
            alert("Security PIN must be at least 4 digits.");
        }
    }

    function logoutVault() {
        isLoggedIn = false;
        document.getElementById('vault-auth').classList.remove('hidden');
        document.getElementById('vault-content').classList.add('hidden');
        document.getElementById('vault-pin').value = '';
    }

    function saveToVault() {
        const pass = document.getElementById('generated-output').innerText;
        if(!pass || pass === '••••••••••••') return;
        
        const timestamp = new Date().toLocaleString();
        vaultData.push({ pass, date: timestamp });
        alert("Password securely cached in local session.");
        renderVault();
    }

    function deleteVaultItem(idx) {
        vaultData.splice(idx, 1);
        renderVault();
    }

    function renderVault() {
        const list = document.getElementById('vault-list');
        if(!isLoggedIn) return;

        if(vaultData.length === 0) {
            list.innerHTML = '<div class="text-center py-12 opacity-50 italic text-body-md">Your vault is empty. Generate and save a password to see it here.</div>';
            return;
        }
        
        list.innerHTML = vaultData.map((item, idx) => `
            <div class="p-md bg-surface-container/30 backdrop-blur-md rounded-lg flex items-center justify-between border border-outline-variant/30 group">
                <div class="space-y-xs">
                    <div class="flex items-center gap-sm">
                        <span class="font-mono text-body-lg tracking-wider text-primary">${item.pass}</span>
                    </div>
                    <div class="text-xs text-outline opacity-70">Saved: ${item.date}</div>
                </div>
                <div class="flex gap-xs">
                    <button class="material-symbols-outlined text-outline hover:text-primary p-xs transition-colors" onclick="navigator.clipboard.writeText('${item.pass}')" title="Copy Key">content_copy</button>
                    <button class="material-symbols-outlined text-outline hover:text-error p-xs transition-colors" onclick="deleteVaultItem(${idx})" title="Delete Key">delete</button>
                </div>
            </div>
        `).join('');
    }

    // Run password generator on layout load
    generatePassword();
</script>
</body>
</html>